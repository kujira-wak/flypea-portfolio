---
import type { CollectionEntry } from "astro:content";
import EntryTaxonomy from "./EntryTaxonomy.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
---

<article class="index-row grid gap-5 py-7 md:grid-cols-[7rem_minmax(0,1fr)_auto] md:items-start">
  <div class="grid gap-2">
    <p class="micro-label text-signal">{project.data.status}</p>
    <p class="font-mono text-xs text-muted">{project.data.period ?? project.data.startedAt.getFullYear()}</p>
  </div>
  <div class="grid max-w-3xl gap-4">
    <h2 class="font-display text-2xl font-bold leading-tight tracking-tight md:text-3xl">
      <a class="hover:text-signal" href={`/projects/${project.id}/`}>{project.data.title}</a>
    </h2>
    <p class="text-sm leading-7 text-muted">{project.data.description}</p>
    <EntryTaxonomy topics={project.data.topics} technologies={project.data.technologies} />
  </div>
  <a class="micro-label text-link w-fit" href={`/projects/${project.id}/`}>Open / →</a>
</article>
