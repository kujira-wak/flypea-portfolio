---
interface Props {
  reactionId: string;
}
const { reactionId } = Astro.props;
---

<section class="mt-14 border-y border-ink bg-surface py-6" aria-labelledby={`reaction-title-${reactionId}`} data-note-reaction data-entry-id={reactionId}>
  <div class="flex flex-wrap items-center justify-between gap-5">
    <div class="grid gap-1">
      <p class="micro-label text-signal">Reader signal</p>
      <h2 id={`reaction-title-${reactionId}`} class="font-display text-xl font-bold">このNoteは参考になりましたか？</h2>
      <p class="text-xs leading-5 text-muted">同じブラウザからは1回。あとから取り消せます。</p>
    </div>
    <button class="action-link min-w-40" type="button" aria-pressed="false" data-reaction-button><span data-reaction-label>Signal +1</span><span class="ml-3 border-l border-white/40 pl-3" hidden data-reaction-count>0</span></button>
  </div>
  <p class="mt-4 text-xs font-semibold text-muted" aria-live="polite" data-reaction-status>高評価件数を読み込んでいます。</p>
</section>

<script>
  interface ReactionState { count: number; reacted: boolean; }
  interface ReactionResponse { reaction?: ReactionState; reactions?: Record<string, ReactionState>; }
  for (const root of document.querySelectorAll<HTMLElement>("[data-note-reaction]")) {
    const reactionId = root.dataset.entryId;
    const button = root.querySelector<HTMLButtonElement>("[data-reaction-button]");
    const label = root.querySelector<HTMLElement>("[data-reaction-label]");
    const count = root.querySelector<HTMLElement>("[data-reaction-count]");
    const status = root.querySelector<HTMLElement>("[data-reaction-status]");
    if (!reactionId || !button || !label || !count || !status) continue;
    const legacyKey = `flypea:log-reaction:${reactionId}`;
    let state: ReactionState = { count: 0, reacted: false };
    const render = () => { button.setAttribute("aria-pressed", String(state.reacted)); button.classList.toggle("is-reacted", state.reacted); label.textContent = state.reacted ? "Signaled" : "Signal +1"; count.textContent = String(state.count); count.hidden = false; };
    const request = async (method: "GET" | "PUT" | "DELETE") => { const url = method === "GET" ? `/api/reactions/batch?ids=${encodeURIComponent(reactionId)}` : `/api/reactions/${encodeURIComponent(reactionId)}`; const response = await fetch(url, { method, credentials: "same-origin", signal: AbortSignal.timeout(5000) }); if (!response.ok) throw new Error(`Reaction API: ${response.status}`); const body = (await response.json()) as ReactionResponse; return method === "GET" ? body.reactions?.[reactionId] : body.reaction; };
    const load = async () => { button.disabled = true; try { const loaded = await request("GET"); if (!loaded) throw new Error("empty"); state = loaded; let legacy = false; try { legacy = window.localStorage.getItem(legacyKey) === "1"; } catch {} if (legacy && !state.reacted) state = (await request("PUT")) ?? state; if (legacy) { try { window.localStorage.removeItem(legacyKey); } catch {} } render(); status.textContent = "Signalはサイト全体で同期されます。"; button.disabled = false; } catch { status.textContent = "現在Signalを利用できません。Noteはそのまま読めます。"; button.disabled = true; } };
    button.addEventListener("click", async () => { const previous = state; const next = !state.reacted; state = { count: Math.max(0, state.count + (next ? 1 : -1)), reacted: next }; render(); button.disabled = true; status.textContent = "同期しています。"; try { state = (await request(next ? "PUT" : "DELETE")) ?? previous; render(); status.textContent = next ? "Signalを同期しました。" : "Signalを取り消しました。"; } catch { state = previous; render(); status.textContent = "同期できませんでした。時間をおいてお試しください。"; } finally { button.disabled = false; } });
    void load();
  }
</script>
