---
import {
  type StatusId,
  statuses,
  type TechnologyId,
  type TopicId,
  taxonomyPath,
  technologies,
  topics,
} from "../data/taxonomy";

interface Props {
  topics?: readonly TopicId[];
  technologies?: readonly TechnologyId[];
  status?: StatusId;
  compact?: boolean;
}

const {
  topics: topicIds = [],
  technologies: technologyIds = [],
  status,
  compact = false,
} = Astro.props;
---

<div class:list={["flex flex-wrap items-center", compact ? "gap-x-3 gap-y-1" : "gap-x-4 gap-y-2"]}>
  {
    topicIds.map((id) => (
      <a class="micro-label text-muted hover:text-signal" href={taxonomyPath.topic(id)}>
        {topics[id].label}
      </a>
    ))
  }
  {
    technologyIds.map((id) => (
      <a class="micro-label border-b border-line text-ink hover:border-signal" href={taxonomyPath.technology(id)}>
        {technologies[id].label}
      </a>
    ))
  }
  {status && <a class="micro-label text-signal" href={taxonomyPath.status(status)}>{statuses[status].label}</a>}
</div>
