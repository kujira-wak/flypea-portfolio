---
import Container from "./Container.astro";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/index/", label: "Index" },
  { href: "/projects/", label: "Projects" },
  { href: "/notes/", label: "Notes" },
  { href: "/shelf/", label: "Shelf" },
  { href: "/about/", label: "About" },
];

const isCurrent = (href: string) => currentPath === href || currentPath.startsWith(href);
---

<header class="border-b border-ink bg-canvas">
  <Container class="grid min-h-16 gap-3 py-3 md:grid-cols-[1fr_auto_1fr] md:items-center">
    <a class="flex w-fit items-center gap-3" href="/" aria-label="flypea.tech ホーム">
      <img class="h-7 w-7 border border-ink object-cover" src="/images/profile.webp" alt="" width="28" height="28" />
      <span class="micro-label text-ink">flypea.tech</span>
    </a>

    <p class="micro-label hidden text-center md:block">Personal index / issue 001</p>

    <nav class="min-w-0 overflow-x-auto md:justify-self-end" aria-label="メインナビゲーション">
      <ul class="flex w-max items-center gap-1 text-ink">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={[
                  "micro-label block border-b-2 px-2 py-2 transition-colors hover:border-signal hover:text-signal",
                  isCurrent(item.href) ? "border-signal" : "border-transparent",
                ]}
                href={item.href}
                aria-current={isCurrent(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </Container>
</header>
