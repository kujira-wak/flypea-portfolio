---
import type { CollectionEntry } from "astro:content";

interface Props {
  work: CollectionEntry<"works">;
}

const { work } = Astro.props;

const statusStyles: Record<string, string> = {
  公開中: "border-emerald-200 bg-emerald-50 text-emerald-800",
  整備中: "border-amber-200 bg-amber-50 text-amber-800",
  計画中: "border-zinc-200 bg-zinc-100 text-zinc-600",
};

const detailUrl = `/works/${work.id}/`;
---

<article class="grid h-full gap-5 border border-zinc-200 bg-white p-5 sm:p-6">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div class="grid gap-2">
      <p class="text-xs font-semibold tracking-[0.1em] text-zinc-500 uppercase">Work</p>
      <h3 class="text-xl font-bold text-zinc-950">
        <a class="transition hover:text-emerald-700" href={detailUrl}>{work.data.title}</a>
      </h3>
    </div>
    <span
      class:list={[
        "border px-2.5 py-1 text-xs font-bold",
        statusStyles[work.data.status] ?? "border-zinc-200 bg-zinc-100 text-zinc-600",
      ]}
    >
      {work.data.status}
    </span>
  </div>

  <p class="text-sm leading-7 text-zinc-700">{work.data.description}</p>

  <ul class="flex flex-wrap gap-x-3 gap-y-2" aria-label="使用技術">
    {work.data.tags.map((tag) => <li class="text-xs font-semibold text-zinc-500">#{tag}</li>)}
  </ul>

  <div class="mt-auto flex flex-wrap gap-x-5 gap-y-2 border-t border-zinc-100 pt-4">
    <a class="text-sm font-bold text-emerald-700 underline-offset-4 hover:underline" href={detailUrl}>
      詳しく見る
    </a>
    {
      work.data.liveUrl && (
        <a class="text-sm font-bold text-zinc-700 underline-offset-4 hover:underline" href={work.data.liveUrl}>
          公開サイト
        </a>
      )
    }
    {
      work.data.repositoryUrl && (
        <a
          class="text-sm font-bold text-zinc-700 underline-offset-4 hover:underline"
          href={work.data.repositoryUrl}
        >
          リポジトリ
        </a>
      )
    }
  </div>
</article>
