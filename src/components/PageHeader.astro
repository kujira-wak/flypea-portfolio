---
import Container from "./Container.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  currentLabel: string;
  parent?: {
    href: string;
    label: string;
  };
}

const { eyebrow, title, description, currentLabel, parent } = Astro.props;
---

<section class="border-b border-zinc-200 bg-[#f8f6f0]">
  <Container class="grid gap-8 py-12 sm:py-16">
    <nav aria-label="パンくずリスト">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-zinc-500">
        <li><a class="transition hover:text-emerald-700" href="/">Home</a></li>
        <li aria-hidden="true">/</li>
        {
          parent && (
            <>
              <li>
                <a class="transition hover:text-emerald-700" href={parent.href}>
                  {parent.label}
                </a>
              </li>
              <li aria-hidden="true">/</li>
            </>
          )
        }
        <li class="font-semibold text-zinc-950" aria-current="page">{currentLabel}</li>
      </ol>
    </nav>

    <div class="grid max-w-3xl gap-4">
      <p class="text-sm font-semibold tracking-[0.12em] text-emerald-700 uppercase">{eyebrow}</p>
      <h1 class="text-4xl font-bold leading-tight text-zinc-950 sm:text-5xl">{title}</h1>
      <p class="max-w-2xl text-base leading-8 text-zinc-700 sm:text-lg">{description}</p>
    </div>
  </Container>
</section>
