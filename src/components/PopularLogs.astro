---
import type { CollectionEntry } from "astro:content";
import LogItem from "./LogItem.astro";

interface Props {
  entries: CollectionEntry<"learningLog">[];
  limit?: number;
}

const { entries, limit = 3 } = Astro.props;
---

<div data-popular-log-list data-limit={limit}>
  {entries.map((entry) => <LogItem entry={entry} />)}
</div>
<p class="mt-4 text-sm text-zinc-500" data-popular-log-status>高評価件数を読み込んでいます。</p>

<script>
  for (const list of document.querySelectorAll<HTMLElement>("[data-popular-log-list]")) {
    const items = Array.from(list.querySelectorAll<HTMLElement>("[data-log-item]"));
    const limit = Number(list.dataset.limit ?? 3);
    const status = list.nextElementSibling as HTMLElement | null;
    for (const item of items) item.hidden = true;

    window.addEventListener(
      "flypea:reactions-loaded",
      (event) => {
        const ok = (event as CustomEvent<{ ok: boolean }>).detail.ok;
        if (!ok) {
          if (status) status.textContent = "現在、高評価件数を取得できません。";
          return;
        }

        const sorted = [...items].sort((a, b) => {
          const countDifference = Number(b.dataset.reactionCount ?? 0) - Number(a.dataset.reactionCount ?? 0);
          if (countDifference !== 0) return countDifference;
          return new Date(b.dataset.publishedAt ?? 0).valueOf() - new Date(a.dataset.publishedAt ?? 0).valueOf();
        });
        for (const [index, item] of sorted.entries()) {
          item.hidden = index >= limit;
          list.append(item);
        }
        if (status) {
          const hasReactions = sorted.some((item) => Number(item.dataset.reactionCount ?? 0) > 0);
          status.textContent = hasReactions ? "みんなの高評価順です。" : "まだ高評価がないため、新しい記事から表示しています。";
        }
      },
      { once: true },
    );
  }
</script>
