---
import { siteConfig } from "../config/site";
import Container from "./Container.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 bg-zinc-950 py-10 text-zinc-300">
  <Container class="grid gap-8 sm:grid-cols-[1fr_auto] sm:items-end">
    <div class="grid gap-3">
      <a class="w-fit text-sm font-bold tracking-[0.12em] text-white" href="/">flypea.tech</a>
      <p class="max-w-xl text-sm leading-6 text-zinc-400">
        制作物とWeb開発の学習記録を、公開しながら育てる静的サイトです。
      </p>
    </div>
    <div class="grid gap-4 text-sm sm:justify-items-end">
      <nav aria-label="フッターナビゲーション">
        <ul class="flex flex-wrap gap-x-5 gap-y-2">
          <li><a class="transition hover:text-white" href="/works/">Works</a></li>
          <li><a class="transition hover:text-white" href="/log/">Log</a></li>
          <li><a class="transition hover:text-white" href="/profile/">Profile</a></li>
          <li><a class="transition hover:text-white" href={siteConfig.githubUrl}>GitHub</a></li>
        </ul>
      </nav>
      <p class="text-xs text-zinc-500">&copy; {year} {siteConfig.author}</p>
    </div>
  </Container>
</footer>
