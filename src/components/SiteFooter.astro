---
import { siteConfig } from "../config/site";
import Container from "./Container.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-ink bg-ink text-white">
  <Container class="grid gap-10 py-10 md:grid-cols-[1fr_auto] md:items-end">
    <div class="grid gap-4">
      <p class="micro-label text-signal">Personal archive / flypea.tech</p>
      <p class="max-w-xl text-sm leading-7 text-white/75">
        音楽、ゲーム、デバイス、ソフトウェア、制作、OSS、Notesを同じ目録で辿る個人サイトです。
      </p>
    </div>
    <div class="grid gap-5 text-sm md:justify-items-end">
      <nav aria-label="フッターナビゲーション">
        <ul class="flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs uppercase">
          <li><a class="hover:text-signal" href="/index/">Index</a></li>
          <li><a class="hover:text-signal" href="/projects/">Projects</a></li>
          <li><a class="hover:text-signal" href="/notes/">Notes</a></li>
          <li><a class="hover:text-signal" href="/shelf/">Shelf</a></li>
          <li><a class="hover:text-signal" href="/about/">About</a></li>
          <li><a class="hover:text-signal" href={siteConfig.githubUrl}>GitHub</a></li>
        </ul>
      </nav>
      <p class="font-mono text-xs text-white/50">&copy; {year} {siteConfig.author}</p>
    </div>
  </Container>
</footer>
