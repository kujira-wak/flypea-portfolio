---
import { currentSignals } from "../data/signals";

const rows = currentSignals.filter(({ value }) => Boolean(value));
---

<section class="grid h-full content-between gap-8 bg-signal p-cell text-ink" aria-labelledby="current-signal-title">
  <div>
    <p class="micro-label">Now / current signal</p>
    <h2 id="current-signal-title" class="mt-8 font-display text-4xl font-extrabold leading-[0.9] tracking-tight md:text-5xl">PLAY.<br />LISTEN.<br />BUILD.</h2>
  </div>
  <dl class="grid gap-3 border-t border-ink pt-4 text-sm leading-6">
    {rows.map(({ label, value }) => (
      <div class="grid grid-cols-[6.5rem_1fr] gap-3">
        <dt class="micro-label">{label}</dt>
        <dd>{value}</dd>
      </div>
    ))}
  </dl>
</section>
