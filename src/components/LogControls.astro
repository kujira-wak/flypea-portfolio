---
interface Props {
  tags: string[];
  total: number;
}

const { tags, total } = Astro.props;
---

<section
  class="mb-8 grid gap-5 border border-zinc-200 bg-white p-5 sm:p-6"
  aria-labelledby="log-controls-title"
  data-log-controls
>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs font-bold tracking-[0.1em] text-emerald-700 uppercase">Filter & sort</p>
      <h2 id="log-controls-title" class="mt-1 text-lg font-bold text-zinc-950">記事を絞り込む</h2>
    </div>
    <p class="text-sm font-semibold text-zinc-600" aria-live="polite">
      <span data-log-count>{total}</span>件を表示
    </p>
  </div>

  <div class="grid gap-4">
    <div>
      <p class="mb-2 text-xs font-bold text-zinc-500">タグ</p>
      <div class="flex flex-wrap gap-2" role="group" aria-label="タグで絞り込む">
        <button
          class="border border-emerald-700 bg-emerald-700 px-3 py-2 text-sm font-bold text-white transition hover:bg-emerald-800"
          type="button"
          aria-pressed="true"
          data-log-tag=""
        >
          すべて
        </button>
        {
          tags.map((tag) => (
            <button
              class="border border-zinc-300 bg-white px-3 py-2 text-sm font-bold text-zinc-700 transition hover:border-emerald-700 hover:text-emerald-700"
              type="button"
              aria-pressed="false"
              data-log-tag={tag}
            >
              #{tag}
            </button>
          ))
        }
      </div>
    </div>

    <label class="grid max-w-xs gap-2 text-xs font-bold text-zinc-500" for="log-sort">
      並べ替え
      <select
        id="log-sort"
        class="border border-zinc-300 bg-white px-3 py-2.5 text-sm font-semibold text-zinc-950 focus:border-emerald-700"
        data-log-sort
      >
        <option value="newest">新しい順</option>
        <option value="oldest">古い順</option>
        <option value="title">タイトル順</option>
        <option value="popular">高評価順</option>
      </select>
    </label>

    <button
      class="w-fit border border-zinc-300 bg-white px-3 py-2 text-sm font-bold text-zinc-700 transition hover:border-emerald-700 hover:text-emerald-700 disabled:cursor-wait disabled:opacity-50"
      type="button"
      aria-pressed="false"
      disabled
      data-log-liked
    >
      自分が高評価した記事だけ
    </button>
  </div>

  <p class="border-t border-zinc-200 pt-4 text-sm font-semibold text-zinc-600" hidden data-log-empty>
    条件に一致する記事はありません。
  </p>
</section>

<script>
  const controls = document.querySelector<HTMLElement>("[data-log-controls]");
  const list = document.querySelector<HTMLElement>("[data-log-list]");

  if (controls && list) {
    const items = Array.from(list.querySelectorAll<HTMLElement>("[data-log-item]"));
    const tagButtons = Array.from(
      controls.querySelectorAll<HTMLButtonElement>("[data-log-tag]"),
    );
    const sortSelect = controls.querySelector<HTMLSelectElement>("[data-log-sort]");
    const count = controls.querySelector<HTMLElement>("[data-log-count]");
    const empty = controls.querySelector<HTMLElement>("[data-log-empty]");
    const likedButton = controls.querySelector<HTMLButtonElement>("[data-log-liked]");
    const availableTags = new Set(tagButtons.map((button) => button.dataset.logTag ?? ""));
    const params = new URLSearchParams(window.location.search);
    const requestedTag = params.get("tag") ?? "";
    const requestedSort = params.get("sort") ?? "newest";
    let activeTag = availableTags.has(requestedTag) ? requestedTag : "";
    let activeSort = ["newest", "oldest", "title", "popular"].includes(requestedSort)
      ? requestedSort
      : "newest";
    let activeLiked = params.get("liked") === "1";
    let reactionsReady = false;

    const setButtonState = () => {
      for (const button of tagButtons) {
        const isActive = (button.dataset.logTag ?? "") === activeTag;
        button.setAttribute("aria-pressed", String(isActive));
        button.classList.toggle("border-emerald-700", isActive);
        button.classList.toggle("bg-emerald-700", isActive);
        button.classList.toggle("text-white", isActive);
        button.classList.toggle("border-zinc-300", !isActive);
        button.classList.toggle("bg-white", !isActive);
        button.classList.toggle("text-zinc-700", !isActive);
      }
    };

    const updateUrl = () => {
      const nextParams = new URLSearchParams();
      if (activeTag) nextParams.set("tag", activeTag);
      if (activeSort !== "newest") nextParams.set("sort", activeSort);
      if (activeLiked) nextParams.set("liked", "1");
      const query = nextParams.toString();
      window.history.replaceState({}, "", `${window.location.pathname}${query ? `?${query}` : ""}`);
    };

    const applyState = () => {
      const sortedItems = [...items].sort((a, b) => {
        if (activeSort === "popular") {
          const countDifference =
            Number(b.dataset.reactionCount ?? 0) - Number(a.dataset.reactionCount ?? 0);
          if (countDifference !== 0) return countDifference;
        }
        if (activeSort === "title") {
          return (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "", "ja");
        }

        const difference =
          new Date(b.dataset.publishedAt ?? 0).valueOf() -
          new Date(a.dataset.publishedAt ?? 0).valueOf();
        return activeSort === "oldest" ? -difference : difference;
      });

      let visibleCount = 0;
      for (const item of sortedItems) {
        const itemTags = JSON.parse(item.dataset.logTags ?? "[]") as string[];
        const matchesTag = !activeTag || itemTags.includes(activeTag);
        const matchesLiked = !activeLiked || !reactionsReady || item.dataset.reacted === "true";
        const isVisible = matchesTag && matchesLiked;
        item.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
        list.append(item);
      }

      if (count) count.textContent = String(visibleCount);
      if (empty) empty.hidden = visibleCount !== 0;
      setButtonState();
      if (likedButton) {
        likedButton.setAttribute("aria-pressed", String(activeLiked));
        likedButton.classList.toggle("border-emerald-700", activeLiked);
        likedButton.classList.toggle("bg-emerald-700", activeLiked);
        likedButton.classList.toggle("text-white", activeLiked);
      }
      updateUrl();
    };

    for (const button of tagButtons) {
      button.addEventListener("click", () => {
        activeTag = button.dataset.logTag ?? "";
        applyState();
      });
    }

    if (sortSelect) {
      sortSelect.value = activeSort;
      sortSelect.addEventListener("change", () => {
        activeSort = sortSelect.value;
        applyState();
      });
    }

    likedButton?.addEventListener("click", () => {
      activeLiked = !activeLiked;
      applyState();
    });

    window.addEventListener("flypea:reactions-loaded", (event) => {
      reactionsReady = (event as CustomEvent<{ ok: boolean }>).detail.ok;
      if (likedButton) {
        likedButton.disabled = !reactionsReady;
        likedButton.title = reactionsReady ? "" : "現在、高評価情報を取得できません";
      }
      if (!reactionsReady && activeLiked) activeLiked = false;
      applyState();
    });

    applyState();
  }
</script>
