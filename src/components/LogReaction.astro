---
interface Props {
  entryId: string;
}

const { entryId } = Astro.props;
---

<section
  class="mt-10 border border-zinc-200 bg-white p-5 sm:p-6"
  aria-labelledby={`reaction-title-${entryId}`}
  data-log-reaction
  data-entry-id={entryId}
>
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h2 id={`reaction-title-${entryId}`} class="text-lg font-bold text-zinc-950">
        この記事は参考になりましたか？
      </h2>
      <p class="mt-1 text-xs leading-5 text-zinc-500">
        同じブラウザからは1記事につき1回。あとから取り消せます。
      </p>
    </div>
    <button
      class="inline-flex min-w-36 items-center justify-center border border-zinc-950 bg-zinc-950 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-700"
      type="button"
      aria-pressed="false"
      data-reaction-button
    >
      <span aria-hidden="true">👍</span>
      <span class="ml-2" data-reaction-label>参考になった</span>
      <span class="ml-2 border-l border-white/40 pl-2" hidden data-reaction-count>0</span>
    </button>
  </div>
  <p class="mt-3 text-xs font-semibold text-zinc-500" aria-live="polite" data-reaction-status>
    高評価件数を読み込んでいます。
  </p>
</section>

<script>
  interface ReactionState {
    count: number;
    reacted: boolean;
  }

  interface ReactionResponse {
    reaction?: ReactionState;
    reactions?: Record<string, ReactionState>;
  }

  for (const root of document.querySelectorAll<HTMLElement>("[data-log-reaction]")) {
    const entryId = root.dataset.entryId;
    const button = root.querySelector<HTMLButtonElement>("[data-reaction-button]");
    const label = root.querySelector<HTMLElement>("[data-reaction-label]");
    const count = root.querySelector<HTMLElement>("[data-reaction-count]");
    const status = root.querySelector<HTMLElement>("[data-reaction-status]");
    if (!entryId || !button || !label || !count || !status) continue;

    const storageKey = `flypea:log-reaction:${entryId}`;
    let state: ReactionState = { count: 0, reacted: false };

    const render = () => {
      button.setAttribute("aria-pressed", String(state.reacted));
      button.classList.toggle("border-emerald-700", state.reacted);
      button.classList.toggle("bg-emerald-700", state.reacted);
      button.classList.toggle("border-zinc-950", !state.reacted);
      button.classList.toggle("bg-zinc-950", !state.reacted);
      label.textContent = state.reacted ? "高評価済み" : "参考になった";
      count.textContent = String(state.count);
      count.hidden = false;
    };

    const request = async (method: "GET" | "PUT" | "DELETE") => {
      const url = method === "GET" ? `/api/reactions/batch?ids=${encodeURIComponent(entryId)}` : `/api/reactions/${encodeURIComponent(entryId)}`;
      const response = await fetch(url, {
        method,
        credentials: "same-origin",
        signal: AbortSignal.timeout(5000),
      });
      if (!response.ok) throw new Error(`Reaction API: ${response.status}`);
      const body = (await response.json()) as ReactionResponse;
      return method === "GET" ? body.reactions?.[entryId] : body.reaction;
    };

    const load = async () => {
      button.disabled = true;
      try {
        const loaded = await request("GET");
        if (!loaded) throw new Error("Reaction API response is empty");
        state = loaded;

        let legacyReaction = false;
        try {
          legacyReaction = window.localStorage.getItem(storageKey) === "1";
        } catch {
          // localStorageが無効でもD1の状態は利用できます。
        }
        if (legacyReaction && !state.reacted) {
          state = (await request("PUT")) ?? state;
        }
        if (legacyReaction) {
          try {
            window.localStorage.removeItem(storageKey);
          } catch {
            // 移行後に削除できなくても、PUTは冪等なので重複しません。
          }
        }

        render();
        status.textContent = "高評価はサイト全体で同期されます。";
        button.disabled = false;
      } catch {
        status.textContent = "現在、高評価機能を利用できません。記事はそのまま読めます。";
        button.disabled = true;
      }
    };

    button.addEventListener("click", async () => {
      const previous = state;
      const nextReacted = !state.reacted;
      state = { count: Math.max(0, state.count + (nextReacted ? 1 : -1)), reacted: nextReacted };
      render();
      button.disabled = true;
      status.textContent = "同期しています。";
      try {
        state = (await request(nextReacted ? "PUT" : "DELETE")) ?? previous;
        render();
        status.textContent = nextReacted ? "高評価を同期しました。" : "高評価を取り消しました。";
      } catch {
        state = previous;
        render();
        status.textContent = "同期できませんでした。時間をおいてもう一度お試しください。";
      } finally {
        button.disabled = false;
      }
    });

    void load();
  }
</script>
