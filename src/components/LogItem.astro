---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"learningLog">;
}

const { entry } = Astro.props;
const date = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(entry.data.publishedAt);
---

<article class="grid gap-3 border-t border-zinc-200 py-6 first:border-t-0 first:pt-0">
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-semibold text-zinc-500">
    <time datetime={entry.data.publishedAt.toISOString()}>{date}</time>
    <ul class="flex flex-wrap gap-2" aria-label="タグ">
      {entry.data.tags.map((tag) => <li>#{tag}</li>)}
    </ul>
  </div>
  <h3 class="text-xl font-bold leading-snug text-zinc-950">
    <a class="transition hover:text-emerald-700" href={`/log/${entry.id}/`}>{entry.data.title}</a>
  </h3>
  <p class="text-sm leading-7 text-zinc-700">{entry.data.description}</p>
  <a class="w-fit text-sm font-bold text-emerald-700 underline-offset-4 hover:underline" href={`/log/${entry.id}/`}>
    続きを読む
  </a>
</article>
