---
import Container from "./Container.astro";

interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
  class?: string;
}

const { id, eyebrow, title, description, class: className = "" } = Astro.props;
---

<section id={id} class:list={["py-16 sm:py-24", className]}>
  <Container>
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:gap-14">
      <header class="max-w-xl">
        {eyebrow && <p class="text-sm font-semibold uppercase text-emerald-700">{eyebrow}</p>}
        <h2 class="mt-3 text-3xl font-bold leading-tight text-zinc-950 sm:text-4xl">{title}</h2>
        {
          description && (
            <p class="mt-4 text-base leading-8 text-zinc-700 sm:text-lg">{description}</p>
          )
        }
      </header>
      <div>
        <slot />
      </div>
    </div>
  </Container>
</section>
