---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { siteConfig } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  robots?: string;
  ogType?: "website" | "article";
  image?: string;
  publishedAt?: Date;
  updatedAt?: Date;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  pathname = "/",
  robots,
  ogType = "website",
  image = "/og.png",
  publishedAt,
  updatedAt,
} = Astro.props;
const pageTitle = title === siteConfig.title ? title : `${title} | ${siteConfig.name}`;
const canonicalUrl = new URL(pathname, siteConfig.url);
const imageUrl = new URL(image, siteConfig.url);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#F5F3EB" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="flypea.tech — Framed Signal" />
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">本文へ移動</a>
    <div class="flex min-h-screen flex-col">
      <SiteHeader />
      <div class="flex-1">
        <slot />
      </div>
      <SiteFooter />
    </div>
  </body>
</html>
