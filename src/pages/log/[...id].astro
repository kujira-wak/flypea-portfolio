---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "../../components/Container.astro";
import LogReaction from "../../components/LogReaction.astro";
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("learningLog", ({ data }) => !data.draft);

  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"learningLog">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(entry.data.publishedAt);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  pathname={`/log/${entry.id}/`}
>
  <main id="main-content">
    <PageHeader
      eyebrow="Learning Log"
      title={entry.data.title}
      description={entry.data.description}
      currentLabel={entry.data.title}
      parent={{ href: "/log/", label: "Log" }}
    />

    <article class="py-12 sm:py-16">
      <Container class="grid gap-8 lg:grid-cols-[0.45fr_1.55fr] lg:gap-12">
        <aside class="text-sm text-zinc-600">
          <time datetime={entry.data.publishedAt.toISOString()}>{date}</time>
          <ul class="mt-3 flex flex-wrap gap-2" aria-label="タグ">
            {entry.data.tags.map((tag) => <li class="font-semibold">#{tag}</li>)}
          </ul>
        </aside>
        <div>
          <div class="prose-content">
            <Content />
          </div>
          <LogReaction entryId={entry.id} />
          <div class="mt-10 border-t border-zinc-200 pt-6">
            <a class="text-sm font-bold text-emerald-700 underline-offset-4 hover:underline" href="/log/">
              Learning Log一覧へ戻る
            </a>
          </div>
        </div>
      </Container>
    </article>
  </main>
</BaseLayout>
