---
import { getCollection } from "astro:content";
import Container from "../../components/Container.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const logs = (await getCollection("learningLog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
const dateFormatter = new Intl.DateTimeFormat("ja-JP", { dateStyle: "long" });
---

<BaseLayout title="Learning Log" description="Web開発の学習と制作の記録です。" pathname="/log/">
  <main id="main-content">
    <Container class="grid gap-10 py-10 sm:py-16">
      <header class="grid gap-5 border-b border-zinc-300 pb-8">
        <a class="text-sm font-bold text-emerald-700" href="/">← Home</a>
        <p class="text-sm font-semibold tracking-[0.16em] text-emerald-700 uppercase">Learning Log</p>
        <h1 class="text-4xl font-bold text-zinc-950 sm:text-6xl">学習ログ</h1>
        <p class="max-w-2xl text-lg leading-8 text-zinc-700">作ったもの、学んだこと、判断した理由をMarkdownで残します。</p>
      </header>
      <ol class="grid gap-5">
        {logs.map((log) => (
          <li class="border border-zinc-200 bg-white p-5">
            <time class="text-xs font-bold text-emerald-700">{dateFormatter.format(log.data.publishedAt)}</time>
            <h2 class="mt-2 text-xl font-bold text-zinc-950">
              <a class="transition hover:text-emerald-700" href={`/log/${log.id}/`}>{log.data.title}</a>
            </h2>
            <p class="mt-3 text-sm leading-7 text-zinc-700">{log.data.description}</p>
          </li>
        ))}
      </ol>
    </Container>
  </main>
</BaseLayout>
