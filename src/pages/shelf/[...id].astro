---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "../../components/Container.astro";
import EntryTaxonomy from "../../components/EntryTaxonomy.astro";
import PageMasthead from "../../components/PageMasthead.astro";
import { shelfKinds } from "../../data/taxonomy";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("shelf", ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}
interface Props {
  entry: CollectionEntry<"shelf">;
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} pathname={`/shelf/${entry.id}/`}>
  <main id="main-content">
    <PageMasthead eyebrow={`Shelf / ${shelfKinds[entry.data.kind].label}`} title={entry.data.title} description={entry.data.description} currentLabel={entry.data.title} parent={{ href: "/shelf/", label: "Shelf" }} />
    <article class="py-section"><Container class="grid gap-12 lg:grid-cols-[4fr_8fr]"><aside class="grid content-start gap-6"><p class="micro-label text-signal">{shelfKinds[entry.data.kind].label}</p>{entry.data.creator && <p>{entry.data.creator}</p>}<EntryTaxonomy topics={entry.data.topics} technologies={entry.data.technologies} status={entry.data.status} />{entry.data.externalUrl && <a class="action-link" href={entry.data.externalUrl}>Open external link</a>}</aside><div class="min-w-0">{entry.data.cover && <Image class="mb-10 h-auto w-full border border-ink" src={entry.data.cover} alt={entry.data.coverAlt ?? ""} loading="eager" />}<div class="prose-content"><Content /></div><p class="mt-12 border-t border-ink pt-5"><a class="micro-label text-link" href="/shelf/">← Shelf index</a></p></div></Container></article>
  </main>
</BaseLayout>
