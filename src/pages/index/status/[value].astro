---
import DirectoryPage from "../../../components/DirectoryPage.astro";
import { STATUS_IDS, type StatusId, statuses } from "../../../data/taxonomy";
import { getAllIndexEntries } from "../../../lib/content-index";

export function getStaticPaths() {
  return STATUS_IDS.map((value) => ({ params: { value } }));
}
const value = Astro.params.value as StatusId;
const item = statuses[value];
const entries = (await getAllIndexEntries()).filter((entry) => entry.status === value);
---
<DirectoryPage title={item.label.toUpperCase()} label={item.label} description={item.description} pathname={`/index/status/${value}/`} entries={entries} />
