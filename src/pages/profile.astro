---
import Container from "../components/Container.astro";
import Section from "../components/Section.astro";
import { siteConfig } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = {
  name: "flypea",
  role: "Web development learner / portfolio builder",
  description:
    "Web制作とWebアプリ開発を、作りながら学んでいます。flypea.techでは、制作物だけでなく、調べたこと、詰まったこと、公開までの流れも残していきます。",
};

const focusItems = [
  {
    title: "小さく作って公開する",
    description: "まずは静的サイトとして軽く公開し、動く状態を保ちながら少しずつ広げます。",
  },
  {
    title: "学習を見える形にする",
    description: "完成したものだけでなく、試行錯誤や判断の理由もログとして残します。",
  },
  {
    title: "Webアプリへ段階的に進む",
    description: "Astroの土台から、Next.js、SolidJS、データベース、テストへ進めていきます。",
  },
];

const nowItems = [
  "Astro + TypeScript + Tailwind CSS v4でポートフォリオを構築",
  "GitHub ActionsからロリポップへSFTPデプロイ",
  "CloudflareでHTTPSとwwwリダイレクトを管理",
  "学習ログと制作物一覧をMarkdownで育てる準備",
];

const nextItems = [
  "WorksとLearning Logをcontent collection化",
  "制作物の詳細ページを追加",
  "app.flypea.techや別リポジトリでWebアプリ学習を開始",
];
---

<BaseLayout
  title="Profile"
  description="flypea.techを作っている人の軽い自己紹介ページです。"
  pathname="/profile/"
>
  <main id="main-content">
    <section class="border-b border-zinc-200 bg-[#f8f6f0] py-8 sm:py-10">
      <Container class="grid gap-12">
        <header class="flex flex-wrap items-center justify-between gap-4">
          <a class="text-sm font-bold tracking-[0.18em] text-zinc-950 uppercase" href="/">
            flypea.tech
          </a>
          <nav aria-label="ページ移動" class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-zinc-700">
            <a class="transition hover:text-emerald-700" href="/">Home</a>
            <a class="transition hover:text-emerald-700" href="/#works">Works</a>
            <a class="transition hover:text-emerald-700" href="/#log">Log</a>
            <a class="transition hover:text-emerald-700" href={siteConfig.githubUrl}>GitHub</a>
          </nav>
        </header>

        <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-end">
          <div class="grid max-w-3xl gap-6">
            <p class="text-sm font-semibold tracking-[0.16em] text-emerald-700 uppercase">
              Profile
            </p>
            <div class="grid gap-5">
              <h1 class="text-4xl font-bold leading-tight text-zinc-950 sm:text-6xl">
                {profile.name}
              </h1>
              <p class="text-lg font-semibold text-zinc-700">{profile.role}</p>
              <p class="max-w-2xl text-lg leading-8 text-zinc-700">{profile.description}</p>
            </div>
          </div>

          <aside class="border border-zinc-300 bg-white/70 p-6 shadow-[8px_8px_0_0_#111827]">
            <p class="text-xs font-bold tracking-[0.14em] text-zinc-500 uppercase">Current mode</p>
            <p class="mt-3 text-2xl font-bold leading-snug text-zinc-950">
              静的サイトを入口に、制作と学習を積み上げる。
            </p>
          </aside>
        </div>
      </Container>
    </section>

    <Section
      id="focus"
      eyebrow="Focus"
      title="大事にしていること"
      description="まだ大きな肩書きを置くより、今は作る姿勢と学び方が伝わるページにします。"
    >
      <div class="grid gap-4">
        {
          focusItems.map((item) => (
            <article class="border border-zinc-200 bg-white p-5">
              <h3 class="text-lg font-bold text-zinc-950">{item.title}</h3>
              <p class="mt-2 text-sm leading-7 text-zinc-700">{item.description}</p>
            </article>
          ))
        }
      </div>
    </Section>

    <Section
      id="now"
      eyebrow="Now"
      title="いま取り組んでいること"
      description="flypea.techを、軽くて壊れにくいポートフォリオ兼学習ログとして整えています。"
      class="bg-white/45"
    >
      <ul class="grid gap-3">
        {
          nowItems.map((item) => (
            <li class="border-l-2 border-emerald-600 bg-white px-4 py-3 text-sm font-semibold leading-7 text-zinc-800">
              {item}
            </li>
          ))
        }
      </ul>
    </Section>

    <Section
      id="next"
      eyebrow="Next"
      title="次にやること"
      description="CMSを足す前に、MarkdownとGitで軽く育てられる形を先に作ります。"
    >
      <div class="grid gap-5">
        <ol class="grid gap-3">
          {
            nextItems.map((item, index) => (
              <li class="grid grid-cols-[auto_1fr] gap-3 border border-zinc-200 bg-white p-4">
                <span class="text-sm font-bold text-emerald-700">{String(index + 1).padStart(2, "0")}</span>
                <span class="text-sm font-semibold leading-7 text-zinc-800">{item}</span>
              </li>
            ))
          }
        </ol>
        <div class="flex flex-wrap gap-3">
          <a
            class="inline-flex items-center justify-center border border-zinc-950 bg-zinc-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-700"
            href="/"
          >
            Homeへ戻る
          </a>
          <a
            class="inline-flex items-center justify-center border border-zinc-300 px-5 py-3 text-sm font-bold text-zinc-950 transition hover:border-emerald-700 hover:text-emerald-700"
            href={siteConfig.githubUrl}
          >
            GitHubを見る
          </a>
        </div>
      </div>
    </Section>
  </main>
</BaseLayout>
