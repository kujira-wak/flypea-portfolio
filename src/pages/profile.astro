---
import Container from "../components/Container.astro";
import Section from "../components/Section.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { profileContent } from "../data/profile";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title={profileContent.meta.title}
  description={profileContent.meta.description}
  pathname={profileContent.meta.pathname}
>
  <main id="main-content">
    <section class="border-b border-zinc-200 bg-[#f8f6f0]">
      <Container class="grid gap-8 py-12 sm:py-16">
        <nav aria-label="パンくずリスト">
          <ol class="flex items-center gap-2 text-sm text-zinc-500">
            <li><a class="transition hover:text-emerald-700" href="/">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="font-semibold text-zinc-950" aria-current="page">Profile</li>
          </ol>
        </nav>

        <div class="grid max-w-3xl gap-6">
          <div class="flex items-start gap-5 sm:gap-7">
            {
              profileContent.profile.image ? (
                <img
                  class="aspect-square w-24 shrink-0 border border-zinc-300 bg-white object-cover shadow-[6px_6px_0_0_#111827] sm:w-32 lg:w-40"
                  src={profileContent.profile.image.src}
                  alt={profileContent.profile.image.alt}
                  width="160"
                  height="160"
                />
              ) : (
                <div
                  class="grid aspect-square w-24 shrink-0 place-items-center border border-zinc-300 bg-zinc-950 text-2xl font-bold text-white shadow-[6px_6px_0_0_#047857] sm:w-32 sm:text-3xl lg:w-40"
                  aria-hidden="true"
                >
                  {profileContent.profile.fallbackInitials}
                </div>
              )
            }
            <div class="grid min-w-0 gap-2 pt-1 sm:gap-3 sm:pt-2">
              <p class="text-sm font-semibold tracking-[0.12em] text-emerald-700 uppercase">Profile</p>
              <h1 class="text-3xl font-bold leading-tight text-zinc-950 sm:text-5xl">
                {profileContent.profile.name}
              </h1>
              <p class="text-base font-semibold leading-7 text-zinc-700 sm:text-lg">
                {profileContent.profile.role}
              </p>
            </div>
          </div>
          <p class="max-w-2xl text-base leading-8 text-zinc-700 sm:text-lg">
            {profileContent.profile.description}
          </p>
          <p class="border-l-2 border-emerald-700 pl-4 text-sm font-bold leading-7 text-zinc-950">
            {profileContent.profile.currentMode}
          </p>
        </div>
      </Container>
    </section>

    <Section
      id="links"
      eyebrow="Links"
      title="SNSと関連リンク"
      description="活動の記録、短い近況、このサイトのコードへ移動できます。"
    >
      <div class="grid gap-4 sm:grid-cols-2">
        {
          profileContent.links.map((link) => (
            <a
              class="group flex min-h-24 items-center gap-4 border border-zinc-200 bg-white p-5 text-zinc-950 transition hover:border-emerald-700 hover:shadow-[5px_5px_0_0_#047857]"
              href={link.href}
            >
              <span class="flex h-11 w-11 shrink-0 items-center justify-center border border-zinc-200 bg-zinc-50 transition group-hover:border-emerald-700 group-hover:text-emerald-700">
                <SocialIcon name={link.icon} />
              </span>
              <span class="grid gap-1">
                <span class="text-lg font-bold">{link.label}</span>
                <span class="text-sm leading-6 text-zinc-600">{link.description}</span>
              </span>
            </a>
          ))
        }
      </div>
    </Section>

    <Section
      id="skills"
      eyebrow="Skills"
      title="使っている技術と学習中の領域"
      description="経験済みと学習予定を分けて、現在地が分かるようにしています。"
      class="bg-white/55"
    >
      <div class="grid gap-4">
        {
          profileContent.skillGroups.map((group) => (
            <article class="grid gap-4 border border-zinc-200 bg-white p-5 sm:grid-cols-[0.7fr_1.3fr] sm:items-start">
              <h3 class="text-lg font-bold text-zinc-950">{group.title}</h3>
              <ul class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <li class="border border-zinc-200 bg-zinc-50 px-3 py-2 text-sm font-semibold text-zinc-700">
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </Section>

    <Section
      id="focus"
      eyebrow="Focus"
      title="大事にしていること"
      description="完成度を待ち続けず、小さく公開して改善を重ねることを意識しています。"
    >
      <div class="grid gap-4">
        {
          profileContent.focusItems.map((item) => (
            <article class="border-t border-zinc-300 pt-4">
              <h3 class="text-lg font-bold text-zinc-950">{item.title}</h3>
              <p class="mt-2 text-sm leading-7 text-zinc-700">{item.description}</p>
            </article>
          ))
        }
      </div>
    </Section>

    <section class="border-t border-zinc-200 bg-white/55 py-16 sm:py-20">
      <Container>
        <div class="grid gap-10 lg:grid-cols-2 lg:gap-14">
          <div>
            <p class="text-sm font-semibold text-emerald-700 uppercase">Now</p>
            <h2 class="mt-3 text-2xl font-bold text-zinc-950">いま取り組んでいること</h2>
            <ul class="mt-6 grid gap-3">
              {
                profileContent.nowItems.map((item) => (
                  <li class="border-l-2 border-emerald-700 bg-white px-4 py-3 text-sm font-semibold leading-7 text-zinc-800">
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold text-emerald-700 uppercase">Next</p>
            <h2 class="mt-3 text-2xl font-bold text-zinc-950">次にやること</h2>
            <ol class="mt-6 grid gap-3">
              {
                profileContent.nextItems.map((item, index) => (
                  <li class="grid grid-cols-[auto_1fr] gap-3 border border-zinc-200 bg-white p-4">
                    <span class="text-sm font-bold text-emerald-700">{String(index + 1).padStart(2, "0")}</span>
                    <span class="text-sm font-semibold leading-7 text-zinc-800">{item}</span>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </Container>
    </section>
  </main>
</BaseLayout>
