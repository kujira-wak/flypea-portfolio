---
import { getCollection } from "astro:content";
import Container from "../components/Container.astro";
import CurrentSignal from "../components/CurrentSignal.astro";
import FeaturedProject from "../components/FeaturedProject.astro";
import PersonalIndexHero from "../components/PersonalIndexHero.astro";
import RecentIndex from "../components/RecentIndex.astro";
import ShelfPreview from "../components/ShelfPreview.astro";
import TechnologyIndex from "../components/TechnologyIndex.astro";
import TopicDirectory from "../components/TopicDirectory.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllIndexEntries } from "../lib/content-index";

const [projects, shelf, indexEntries] = await Promise.all([
  getCollection("projects", ({ data }) => !data.draft),
  getCollection("shelf", ({ data }) => !data.draft),
  getAllIndexEntries(),
]);
const featuredProject = projects
  .filter(({ data }) => data.featured)
  .sort((a, b) => b.data.order - a.data.order)[0];
const recentEntries = indexEntries.slice(0, 4);
---

<BaseLayout title="Personal Index" description="音楽、ゲーム、デバイス、ソフトウェア、制作、OSS、Notesを同じ目録で辿る個人アーカイブ。">
  <main id="main-content">
    <Container class="border-x border-ink bg-canvas">
      <PersonalIndexHero />
      <div class="grid border-b border-ink lg:grid-cols-[4fr_5fr_3fr]">
        <div class="border-ink lg:border-r"><FeaturedProject project={featuredProject} /></div>
        <div class="border-ink lg:border-r"><RecentIndex entries={recentEntries} /></div>
        <CurrentSignal />
      </div>
      <TopicDirectory entries={indexEntries} />
      {shelf.length ? (
        <div class="grid border-y border-ink lg:grid-cols-2">
          <div class="border-ink lg:border-r"><ShelfPreview entries={shelf.slice(0, 4)} /></div>
          <TechnologyIndex entries={indexEntries} limit={8} />
        </div>
      ) : (
        <div class="border-y border-ink"><TechnologyIndex entries={indexEntries} limit={8} /></div>
      )}
    </Container>
  </main>
</BaseLayout>
