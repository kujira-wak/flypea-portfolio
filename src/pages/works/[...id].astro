---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection, render } from "astro:content";
import Container from "../../components/Container.astro";
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft);

  return works.map((work) => ({
    params: { id: work.id },
    props: { work },
  }));
}

interface Props {
  work: CollectionEntry<"works">;
}

const { work } = Astro.props;
const { Content } = await render(work);
---

<BaseLayout
  title={work.data.title}
  description={work.data.description}
  pathname={`/works/${work.id}/`}
>
  <main id="main-content">
    <PageHeader
      eyebrow="Works"
      title={work.data.title}
      description={work.data.description}
      currentLabel={work.data.title}
      parent={{ href: "/works/", label: "Works" }}
    />

    <article class="py-12 sm:py-16">
      <Container class="grid gap-10 lg:grid-cols-[0.45fr_1.55fr] lg:gap-12">
        <aside class="grid content-start gap-6 text-sm text-zinc-600">
          <dl class="grid gap-4 border-t border-zinc-200 pt-5">
            <div>
              <dt class="text-xs font-bold tracking-[0.1em] text-zinc-500 uppercase">Status</dt>
              <dd class="mt-1 font-bold text-zinc-950">{work.data.status}</dd>
            </div>
            {
              work.data.role && (
                <div>
                  <dt class="text-xs font-bold tracking-[0.1em] text-zinc-500 uppercase">Role</dt>
                  <dd class="mt-1 font-semibold leading-6 text-zinc-800">{work.data.role}</dd>
                </div>
              )
            }
            {
              work.data.period && (
                <div>
                  <dt class="text-xs font-bold tracking-[0.1em] text-zinc-500 uppercase">Period</dt>
                  <dd class="mt-1 font-semibold text-zinc-800">{work.data.period}</dd>
                </div>
              )
            }
          </dl>

          <ul class="flex flex-wrap gap-2" aria-label="使用技術">
            {work.data.tags.map((tag) => <li class="font-semibold">#{tag}</li>)}
          </ul>

          <div class="grid gap-3">
            {
              work.data.liveUrl && (
                <a
                  class="inline-flex items-center justify-center border border-zinc-950 bg-zinc-950 px-4 py-3 font-bold text-white transition hover:bg-emerald-700"
                  href={work.data.liveUrl}
                >
                  公開サイトを見る
                </a>
              )
            }
            {
              work.data.repositoryUrl && (
                <a
                  class="inline-flex items-center justify-center border border-zinc-300 bg-white px-4 py-3 font-bold text-zinc-950 transition hover:border-emerald-700 hover:text-emerald-700"
                  href={work.data.repositoryUrl}
                >
                  リポジトリを見る
                </a>
              )
            }
          </div>
        </aside>

        <div class="min-w-0">
          {
            work.data.cover && (
              <Image
                class="mb-10 h-auto w-full border border-zinc-200 bg-white"
                src={work.data.cover}
                alt={work.data.coverAlt ?? ""}
                loading="eager"
              />
            )
          }
          <div class="prose-content">
            <Content />
          </div>
          <div class="mt-10 border-t border-zinc-200 pt-6">
            <a class="text-sm font-bold text-emerald-700 underline-offset-4 hover:underline" href="/works/">
              Works一覧へ戻る
            </a>
          </div>
        </div>
      </Container>
    </article>
  </main>
</BaseLayout>
